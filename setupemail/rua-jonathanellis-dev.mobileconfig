  <key>PayloadUUID</key><string>AE9F2A4E-3C5D-4B1A-9D8F-4E3A8B7C2DAF</string>
  <key>PayloadVersion</key><integer>1</integer>
  <key>PayloadRemovalDisallowed</key><false/>
</dict>
</plist>
