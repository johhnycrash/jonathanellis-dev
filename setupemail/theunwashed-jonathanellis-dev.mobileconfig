<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>PayloadContent</key>
  <array>
    <dict>
      <key>PayloadType</key><string>com.apple.mail.managed</string>
      <key>PayloadVersion</key><integer>1</integer>
      <key>PayloadIdentifier</key><string>dev.jonathanellis.mail.theunwashed-dev</string>
      <key>PayloadUUID</key><string>C3D4E5F6-A7B8-9012-CDEF-345678901234</string>
      <key>PayloadDisplayName</key><string>theunwashed@jonathanellis.dev</string>
      <key>PayloadDescription</key><string>Configures Mail.app with theunwashed@jonathanellis.dev</string>
      <key>PayloadOrganization</key><string>Jonathan Ellis</string>

      <key>EmailAccountName</key><string>The Unwashed</string>
      <key>EmailAccountDescription</key><string>theunwashed@jonathanellis.dev</string>
      <key>EmailAccountType</key><string>EmailTypeIMAP</string>
      <key>EmailAddress</key><string>theunwashed@jonathanellis.dev</string>

      <key>IncomingMailServerHostName</key><string>mail.jonathanellis.dev</string>
      <key>IncomingMailServerPortNumber</key><integer>993</integer>
      <key>IncomingMailServerUseSSL</key><true/>
      <key>IncomingMailServerAuthentication</key><string>EmailAuthPassword</string>
      <key>IncomingMailServerUsername</key><string>theunwashed@jonathanellis.dev</string>

      <key>OutgoingMailServerHostName</key><string>mail.jonathanellis.dev</string>
      <key>OutgoingMailServerPortNumber</key><integer>587</integer>
      <key>OutgoingMailServerUseSSL</key><true/>
      <key>OutgoingMailServerAuthentication</key><string>EmailAuthPassword</string>
      <key>OutgoingMailServerUsername</key><string>theunwashed@jonathanellis.dev</string>
      <key>OutgoingPasswordSameAsIncomingPassword</key><true/>
      <key>SMTPEnableStartTLS</key><true/>

      <key>PreventMove</key><false/>
      <key>PreventAppSheet</key><false/>
      <key>disableMailRecentsSyncing</key><false/>
    </dict>
  </array>

  <key>PayloadDisplayName</key><string>Jonathan Ellis Mail — theunwashed@jonathanellis.dev</string>
  <key>PayloadDescription</key><string>Installs theunwashed@jonathanellis.dev with correct IMAP and SMTP settings.</string>
  <key>PayloadIdentifier</key><string>dev.jonathanellis.mailsetup.theunwashed-dev</string>
  <key>PayloadOrganization</key><string>Jonathan Ellis</string>
  <key>PayloadType</key><string>Configuration</string>
  <key>PayloadUUID</key><string>D4E5F6A7-B8C9-0123-DEF4-567890123456</string>
  <key>PayloadVersion</key><integer>1</integer>
  <key>PayloadRemovalDisallowed</key><false/>
</dict>
</plist>
